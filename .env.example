# LinkedIn MCP — environment configuration
# Copy this file to `.env` and fill in values as needed.
# NOTE: Credentials below are OPTIONAL. The default flow is a manual,
# headed login (you type credentials + 2FA/captcha by hand) so passwords
# are never stored. These vars only exist for unattended/auto-login setups.

# Optional: pre-fill credentials for auto-login (NOT recommended; manual
# login is preferred and required for 2FA/captcha accounts).
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Logging verbosity for the MCP stdio server and driver.
# One of: error | warn | info | debug | trace
MCP_LOG_LEVEL=info

# Set to 1 when launched by Claude Desktop as an MCP stdio server.
# (Claude Desktop config injects this; you normally do not set it manually.)
LINKEDIN_MCP_STDIO=

# Optional: override the Playwright browsers path (packaged builds set this
# to the bundled chromium inside app resources).
# PLAYWRIGHT_BROWSERS_PATH=
