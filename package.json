{
  "name": "@hamzah1528cloud-web/linkedin-mcp",
  "version": "0.4.3",
  "description": "Drive LinkedIn via Playwright and expose it as an MCP server over stdio. Runs standalone (npx) or as an Electron tray app.",
  "author": "Hamzah Ejaz",
  "license": "MIT",
  "homepage": "https://github.com/hamzah1528cloud-web/linkdeinMCP#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamzah1528cloud-web/linkdeinMCP.git"
  },
  "bugs": {
    "url": "https://github.com/hamzah1528cloud-web/linkdeinMCP/issues"
  },
  "main": "dist/main/index.js",
  "bin": {
    "linkedin-mcp": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "scripts/postinstall.js",
    "resources",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "linkedin",
    "playwright",
    "automation",
    "claude"
  ],
  "scripts": {
    "start": "electron .",
    "mcp": "node dist/cli.js",
    "build": "tsc -p tsconfig.json && npm run build:renderer",
    "build:renderer": "tsc -p tsconfig.renderer.json && npm run copy:renderer && npm run build:react",
    "copy:renderer": "node -e \"const fs=require('fs');fs.mkdirSync('dist/renderer',{recursive:true});fs.copyFileSync('src/renderer/index.html','dist/renderer/index.html')\"",
    "build:react": "esbuild src/renderer/react/main.tsx --bundle --minify --jsx=automatic --format=iife --target=chrome120 --outfile=dist/renderer/connect.js && npm run copy:connect",
    "copy:connect": "node -e \"const fs=require('fs');fs.mkdirSync('dist/renderer',{recursive:true});fs.copyFileSync('src/renderer/react/connect.html','dist/renderer/connect.html')\"",
    "typecheck:react": "tsc -p tsconfig.react.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "dev": "ts-node --project tsconfig.json src/main/index.ts",
    "start:connect": "LINKEDIN_CONNECT_UI=1 electron .",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "register-mcp": "ts-node --project tsconfig.json scripts/register-mcp.ts",
    "test:smoke": "electron test/connect-smoke.js",
    "test:hitl": "ts-node --project tsconfig.json test/hitl/index.ts",
    "test:hitl:all": "ts-node --project tsconfig.json test/hitl/index.ts --include-mutating",
    "gen-icon": "node scripts/gen-icon.js",
    "pack": "npm run gen-icon && npm run build && electron-builder --dir",
    "dist": "npm run gen-icon && npm run build && electron-builder",
    "dist:mac": "npm run gen-icon && npm run build && electron-builder --mac",
    "dist:win": "npm run gen-icon && npm run build && electron-builder --win",
    "dist:linux": "npm run gen-icon && npm run build && electron-builder --linux",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall.js",
    "test:unit": "ts-node --project tsconfig.json test/mutation-gate.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18.3.7",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "extends": "./electron-builder.json"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
